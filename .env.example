# Locker API — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env files.

# PostgreSQL connection string
DATABASE_URL=postgresql://locker:locker@localhost:5432/locker

# Master encryption key — 32 random bytes, base64 encoded
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# JWT signing secret — 32 random bytes, base64 encoded
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Server port
PORT=3001

# Environment
NODE_ENV=development
