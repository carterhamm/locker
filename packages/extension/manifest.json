{
  "manifest_version": 3,
  "name": "Locker",
  "description": "Quickly store API keys to Locker — your secure credential vault for AI agents.",
  "version": "0.1.1",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api-production-449f.up.railway.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Locker — Store API Key"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+K",
        "mac": "MacCtrl+Shift+K"
      },
      "description": "Open Locker to store an API key"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
