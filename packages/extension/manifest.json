{
  "manifest_version": 3,
  "name": "Locker",
  "description": "Quickly store API keys to Locker — your secure credential vault for AI agents.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Locker — Store API Key"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open Locker to store an API key"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
